{
  "buildCommand": "npm run build",
  "outputDirectory": ".tanstack",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    ".tanstack/server/index.js": {
      "runtime": "nodejs20.x"
    }
  }
}